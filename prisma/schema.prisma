// Deepglot – Prisma Schema
// Database: Neon (serverless PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth v5 Required Models ──────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // for credentials provider
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  memberships   OrganizationMember[]
  projectMemberships ProjectMember[]
  sentProjectInvitations ProjectInvitation[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ─── Organizations (SaaS Mandanten) ───────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(FREE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members      OrganizationMember[]
  projects     Project[]
  subscription Subscription?
  usageRecords UsageRecord[]
  translationBatchLogs TranslationBatchLog[]
}

enum Plan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

model OrganizationMember {
  id             String           @id @default(cuid())
  role           OrganizationRole @default(MEMBER)
  createdAt      DateTime         @default(now())

  userId         String
  organizationId String

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
}

// ─── Projects (Websites / WordPress Instanzen) ────────────────────────────

model Project {
  id             String    @id @default(cuid())
  name           String
  domain         String    // e.g. "example.com"
  originalLang   String    @default("de") // ISO 639-1
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  languages      ProjectLanguage[]
  translations   Translation[]
  apiKeys        ApiKey[]
  usageRecords   UsageRecord[]
  glossaryRules  GlossaryRule[]
  urlSlugs       UrlSlug[]
  exclusions     TranslationExclusion[]
  translatedUrls TranslatedUrl[]
  settings       ProjectSettings?
  members        ProjectMember[]
  invitations    ProjectInvitation[]
  domainMappings ProjectDomainMapping[]
  translationBatchLogs TranslationBatchLog[]
  webhookEndpoints WebhookEndpoint[]
  webhookDeliveries WebhookDelivery[]
}

model ProjectLanguage {
  id        String   @id @default(cuid())
  langCode  String   // ISO 639-1, e.g. "en", "fr"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, langCode])
}

// ─── Translations (Übersetzungs-Cache) ────────────────────────────────────

model Translation {
  id             String            @id @default(cuid())
  originalHash   String            // md5 of (originalText + langFrom + langTo)
  originalText   String
  translatedText String
  langFrom       String            // ISO 639-1
  langTo         String            // ISO 639-1
  source         TranslationSource @default(DEEPL)
  isManual       Boolean           @default(false) // manually edited
  wordCount      Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, originalHash])
  @@index([projectId, langFrom, langTo])
}

enum TranslationSource {
  DEEPL
  OPENAI
  GOOGLE
  MANUAL
  MOCK
  IMPORT
}

// ─── API Keys (Plugin-Authentifizierung) ──────────────────────────────────

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  key         String    @unique // hashed
  keyPrefix   String    // first 8 chars for display, e.g. "dg_live_"
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── Stripe Subscriptions ─────────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  stripeCurrentPeriodEnd DateTime?
  status               SubscriptionStatus @default(INACTIVE)
  plan                 Plan               @default(FREE)
  wordsLimit           Int                @default(10000) // words per month
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

// ─── Project Settings ─────────────────────────────────────────────────────

model ProjectSettings {
  id                      String   @id @default(cuid())

  // General
  autoSwitch              Boolean  @default(false)
  displayAiNotice         Boolean  @default(false)
  automaticTranslation    Boolean  @default(true)
  translationMemory       Boolean  @default(false)
  websiteType             String?  // Blog, Corporate, E-Commerce, etc.
  industryType            String?  // Health & medical, etc.
  translationProvider     String?  // openai, openrouter, ollama, openai-compatible, deepl, mock
  translationModel        String?
  translationBaseUrl      String?
  translationApiKeyEncrypted String?
  translationApiKeyUpdatedAt DateTime?
  routingMode             RoutingMode @default(PATH_PREFIX)
  runtimeSyncedAt         DateTime?

  // Language Switcher
  switcherDisplayName     Boolean  @default(true)
  switcherFullName        Boolean  @default(true)
  switcherFlags           Boolean  @default(true)
  switcherDropdown        Boolean  @default(true)
  switcherFlagsType       String   @default("rectangle_mat")
  switcherCustomCss       String?

  // WordPress-specific
  translateEmails         Boolean  @default(false)
  translateSearch         Boolean  @default(false)
  translateAmp            Boolean  @default(false)

  // Page views tracking
  pageViewsEnabled        Boolean  @default(false)

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  projectId String @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

enum RoutingMode {
  PATH_PREFIX
  SUBDOMAIN
}

// ─── Project Members ──────────────────────────────────────────────────────

model ProjectMember {
  id        String      @id @default(cuid())
  email     String
  role      ProjectRole @default(TRANSLATOR)
  langCode  String?     // language they are responsible for
  createdAt DateTime    @default(now())

  projectId String
  userId    String?
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([projectId, email])
  @@index([userId])
}

enum ProjectRole {
  ADMIN
  TRANSLATOR
}

model ProjectInvitation {
  id         String      @id @default(cuid())
  email      String
  role       ProjectRole @default(TRANSLATOR)
  langCode   String?
  tokenHash  String      @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime    @default(now())

  projectId String
  inviterId String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inviter User    @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([projectId, email])
  @@index([expiresAt])
}

// ─── Glossary Rules ───────────────────────────────────────────────────────

model GlossaryRule {
  id             String   @id @default(cuid())
  originalTerm   String
  translatedTerm String
  langFrom       String   // ISO 639-1
  langTo         String   // ISO 639-1
  caseSensitive  Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, originalTerm, langFrom, langTo])
  @@index([projectId, langFrom, langTo])
}

model ProjectDomainMapping {
  id        String   @id @default(cuid())
  host      String   @unique
  langCode  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, langCode])
  @@index([projectId])
}

// ─── URL Slugs (übersetzbare URL-Pfadsegmente) ───────────────────────────

model UrlSlug {
  id             String   @id @default(cuid())
  originalSlug   String
  translatedSlug String?
  langTo         String   // ISO 639-1
  urlCount       Int      @default(0) // how many URLs use this slug
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, originalSlug, langTo])
  @@index([projectId, langTo])
}

// ─── Translation Exclusions ───────────────────────────────────────────────

model TranslationExclusion {
  id        String          @id @default(cuid())
  type      ExclusionType
  value     String          // URL pattern, CSS selector, or regex
  createdAt DateTime        @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, type, value])
  @@index([projectId, type])
}

enum ExclusionType {
  URL         // full URL or wildcard
  CSS_CLASS   // CSS class selector
  CSS_ID      // CSS ID selector
  REGEX       // regex pattern
}

// ─── Translated URLs (Statistiken pro URL) ────────────────────────────────

model TranslatedUrl {
  id          String   @id @default(cuid())
  urlPath     String   // e.g. "/hautkrebsvorsorge-muttermalkontrolle-wien"
  langTo      String   // ISO 639-1
  wordCount   Int      @default(0)
  requestCount Int     @default(0) // how often this URL was translated
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, urlPath, langTo])
  @@index([projectId, langTo])
  @@index([projectId, requestCount(sort: Desc)])
}

model TranslationBatchLog {
  id              String   @id @default(cuid())
  langFrom        String
  langTo          String
  requestUrl      String?
  provider        String
  totalWords      Int      @default(0)
  cachedWords     Int      @default(0)
  manualWords     Int      @default(0)
  glossaryWords   Int      @default(0)
  translatedWords Int      @default(0)
  createdAt       DateTime @default(now())

  organizationId String
  projectId      String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([projectId, createdAt])
  @@index([projectId, langFrom, langTo])
}

// ─── Usage Tracking ───────────────────────────────────────────────────────

model UsageRecord {
  id        String   @id @default(cuid())
  words     Int      // words translated
  month     Int      // YYYYMM, e.g. 202603
  createdAt DateTime @default(now())

  organizationId String
  projectId      String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([organizationId, projectId, month])
  @@index([organizationId, month])
  @@index([projectId, month])
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
}

enum WebhookProcessorRunStatus {
  SUCCESS
  FAILED
}

model WebhookEndpoint {
  id                 String    @id @default(cuid())
  url                String
  secret             String
  eventTypes         String[]
  enabled            Boolean   @default(true)
  lastDeliveryStatus WebhookDeliveryStatus?
  lastDeliveryAt     DateTime?
  lastDeliveryCode   Int?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  deliveries WebhookDelivery[]

  @@index([projectId, enabled])
}

model WebhookDelivery {
  id             String                @id @default(cuid())
  eventType      String
  payload        Json
  status         WebhookDeliveryStatus @default(PENDING)
  attemptCount   Int                   @default(0)
  nextAttemptAt  DateTime              @default(now())
  lastAttemptAt  DateTime?
  responseStatus Int?
  responseBody   String?
  errorMessage   String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  endpointId String
  projectId  String

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  project  Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([endpointId, status, nextAttemptAt])
  @@index([projectId, createdAt])
}

model WebhookProcessorRun {
  id                    String                    @id @default(cuid())
  status                WebhookProcessorRunStatus
  processedCount        Int                       @default(0)
  deliveredCount        Int                       @default(0)
  failedCount           Int                       @default(0)
  pendingRemainingCount Int                       @default(0)
  durationMs            Int                       @default(0)
  errorMessage          String?
  createdAt             DateTime                  @default(now())

  @@index([createdAt])
  @@index([status, createdAt])
}
