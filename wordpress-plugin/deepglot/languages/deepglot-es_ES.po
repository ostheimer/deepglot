#: includes/Api/Client.php:304
msgid "Deepglot API Fehler."
msgstr "Deepglot Error de API."

#: includes/Api/Client.php:219
#: includes/Sync/SettingsSync.php:48
msgid "Kein API-Key für die Synchronisierung vorhanden."
msgstr "No existe API-Key para la sincronización."

#: includes/Api/Client.php:263
msgid "Kein API-Key für die Runtime-Konfiguration vorhanden."
msgstr "No existe API-Key para la configuración del tiempo de ejecución."

#: includes/Api/RestApi.php:203
msgid "Kein API-Key angegeben."
msgstr "No se ha especificado API-Key."

#: includes/Api/RestApi.php:242
msgid "Du benötigst Administrator-Rechte für diese Aktion."
msgstr "Necesita derechos de administrador para esta acción."

#. translators: %d: seconds until reset
#: includes/Api/RestApi.php:281
msgid "Zu viele Anfragen. Bitte warte %d Sekunden."
msgstr "Demasiadas solicitudes. Espere %d segundos."

#: includes/Frontend/LanguageSwitcher.php:236
msgid "Switch language to %s"
msgstr "Cambiar idioma a %s"

#: includes/Frontend/LanguageSwitcher.php:251
msgid "Sprache: %s"
msgstr "Idioma: %s"

#: includes/Frontend/NavMenuSwitcher.php:175
msgid "Sprache wählen"
msgstr "Elige idioma"

#: includes/Frontend/SwitcherBlock.php:61
msgid "Zeigt den Deepglot Sprachschalter — Stile/Flagge/Reihenfolge folgen den Plugin-Einstellungen."
msgstr "Muestra el cambio de idioma Deepglot; los estilos /Flagge/Reihenfolge siguen la configuración del complemento."

#: includes/Frontend/SwitcherWidget.php:26
msgid "Sprachumschalter in einer Widget-Area anzeigen."
msgstr "Muestra el selector de idiomas en un área de widgets."

#: includes/Frontend/SwitcherWidget.php:83
msgid "Titel:"
msgstr "Título:"

