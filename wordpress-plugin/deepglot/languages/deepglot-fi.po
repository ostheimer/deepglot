msgstr "Lisää automaattisesti Switcher sivun alatunnisteeseen"

#: includes/Admin/SettingsPage.php:479
msgid "Alternativ: Shortcode [deepglot_switcher] oder PHP do_action('deepglot_language_switcher') in deinem Theme."
msgstr "Vaihtoehtoisesti: Shortcode [deepglot_switcher] tai PHP do_action('deepglot_language_switcher') teemassasi."

