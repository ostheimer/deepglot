#: includes/Frontend/SwitcherWidget.php:25
#: assets/js/block-switcher.js:19
msgid "Deepglot Sprachschalter"
msgstr "Deepglot Mudança de idioma"

#: includes/Admin/NavMenuMetaBox.php:41
msgid "Fügt einen Sprachschalter-Eintrag hinzu, der beim Anzeigen automatisch in einen Eintrag pro Sprache aufgeklappt wird."
msgstr "Adiciona uma entrada de troca de idioma que se expande automaticamente para uma entrada por idioma quando visualizada."

#: includes/Admin/NavMenuMetaBox.php:44
msgid "Anzeige-Modus"
msgstr "Modo de exibição"

#: includes/Admin/NavMenuMetaBox.php:49
msgid "Liste (jede Sprache als eigener Menüpunkt)"
msgstr "Lista (cada idioma como um item de menu separado)"

#: includes/Admin/NavMenuMetaBox.php:55
msgid "Dropdown (aktive Sprache als Parent, Alternativen als Submenu)"
msgstr "Menu suspenso (idioma ativo como pai, alternativas como submenu)"

#: includes/Admin/NavMenuMetaBox.php:61
msgid "Aktive Sprache aus der Liste ausblenden"
msgstr "Ocultar o idioma ativo da lista"

#: includes/Admin/NavMenuMetaBox.php:71
msgid "Zum Menü hinzufügen"
msgstr "Adicionar ao cardápio"

#: includes/Admin/NavMenuMetaBox.php:98
msgid "Sprachschalter"
msgstr "Interruptor de voz"

#: includes/Admin/SettingsPage.php:171
msgid "Aktiv"
msgstr "Ativo"

#: includes/Admin/SettingsPage.php:174
msgid "Deaktiviert"
msgstr "Desativado"

#: includes/Admin/SettingsPage.php:177
msgid "Einrichtung erforderlich"
msgstr "Configuração necessária"

#: includes/Admin/SettingsPage.php:194
msgid "Willkommen bei Deepglot! Folge den drei Schritten unten, um die Übersetzung deiner Website zu aktivieren."
msgstr "Bem-vindo ao Deepglot! Siga as três etapas abaixo para ativar a tradução em seu site."

#: includes/Admin/SettingsPage.php:205
msgid "Deepglot einrichten"
msgstr "Configurar Deepglot"

#: includes/Admin/SettingsPage.php:206
msgid "Du benötigst nur einen API-Key aus dem Deepglot-Dashboard – das dauert weniger als zwei Minuten."
msgstr "Tudo que você precisa é de um API-Key do painel Deepglot – leva menos de dois minutos."

#: includes/Admin/SettingsPage.php:218
msgid "API-Key eintragen"
msgstr "Digite API-Key"

#: includes/Admin/SettingsPage.php:221
msgid "Erstelle ein kostenloses Konto auf deepglot.app, lege ein Projekt für deine Website an und kopiere den API-Key."
msgstr "Crie uma conta gratuita em deepglot.app, crie um projeto para o seu site e copie o API-Key."

#: includes/Admin/SettingsPage.php:224
msgid "Zum Dashboard – API-Key erstellen"
msgstr "Vá para o painel – crie API-Key"

#: includes/Admin/SettingsPage.php:229
msgid "API-Key"
msgstr "API-Key"

#: includes/Admin/SettingsPage.php:240
msgid "Den vollständigen Schlüssel findest du unter Einstellungen → API-Keys in deinem Deepglot-Projekt."
msgstr "Você pode encontrar a chave completa em Configurações → API-Keys em seu projeto Deepglot."

#: includes/Admin/SettingsPage.php:244
msgid "Backend-URL"
msgstr "Back-end URL"

#: includes/Admin/SettingsPage.php:252
msgid "Standard: https://deepglot.ai/api – nur ändern bei Self-Hosting."
msgstr "Padrão: https://deepglot.ai/api – alteração apenas para Self-Hosting."

#: includes/Admin/SettingsPage.php:264
msgid "Sprachen konfigurieren"
msgstr "Configurar idiomas"

#: includes/Admin/SettingsPage.php:266
msgid "Lege die Originalsprache und die gewünschten Übersetzungssprachen fest."
msgstr "Especifique o idioma original e os idiomas de tradução desejados."

#: includes/Admin/SettingsPage.php:270
msgid "Originalsprache"
msgstr "Idioma original"

#: includes/Admin/SettingsPage.php:281
msgid "Zielsprachen"
msgstr "Idiomas alvo"

#: includes/Admin/SettingsPage.php:289
msgid "Kommagetrennte ISO-639-1-Codes, z. B. en, fr, it"
msgstr "Códigos ISO-639-1 separados por vírgula, por ex. B. en, fr, isto"

#: includes/Admin/SettingsPage.php:301
msgid "Übersetzung aktivieren"
msgstr "Ativar tradução"

#: includes/Admin/SettingsPage.php:303
msgid "Sobald API-Key und Sprachen gespeichert sind, aktiviere die automatische Übersetzung hier."
msgstr "Depois que API-Key e os idiomas forem salvos, habilite a tradução automática aqui."

#: includes/Admin/SettingsPage.php:315
msgid "Deepglot für alle Frontend-Anfragen aktiv schalten"
msgstr "Ative Deepglot para todas as solicitações de front-end"

#. translators: %1$s: source language, %2$s: target languages
#: includes/Admin/SettingsPage.php:324
msgid "Aktiv – Seiten werden von %1$s nach %2$s übersetzt unter /%3$s/ihre-seite/"
msgstr "Ativo – as páginas são traduzidas de %1$s para %2$s em /%3$s/ihre-seite/"

#: includes/Admin/SettingsPage.php:344
msgid "Besucher anhand der Browsersprache automatisch weiterleiten (optional)"
msgstr "Redirecione visitantes automaticamente com base no idioma do navegador (opcional)"

#: includes/Admin/SettingsPage.php:353
msgid "Erweiterte Einstellungen ausblenden"
msgstr "Ocultar configurações avançadas"

#: includes/Admin/SettingsPage.php:353
#: includes/Admin/SettingsPage.php:354
msgid "Erweiterte Einstellungen anzeigen"
msgstr "Mostrar configurações avançadas"

#: includes/Admin/SettingsPage.php:358
msgid "Ausgeschlossene URLs"
msgstr "URLs excluídos"

#: includes/Admin/SettingsPage.php:360
msgid "Eine URL oder ein Muster pro Zeile."
msgstr "Um URL ou padrão por linha."

#: includes/Admin/SettingsPage.php:363
msgid "Routing-Modus"
msgstr "Modo de roteamento"

#: includes/Admin/SettingsPage.php:366
msgid "Pfad-Präfix (/en/meine-seite)"
msgstr "Prefixo do caminho (/en/meine-seite)"

#: includes/Admin/SettingsPage.php:369
msgid "Subdomains (en.example.com)"
msgstr "Subdomínios (en.example.com)"

#: includes/Admin/SettingsPage.php:372
msgid "Pfad-Präfix bleibt der Standard. Für Subdomains braucht jede aktive Zielsprache einen Host."
msgstr "O prefixo do caminho permanece o padrão. Para subdomínios, cada idioma alvo ativo precisa de um host."

#: includes/Admin/SettingsPage.php:375
msgid "Domain-Zuordnungen"
msgstr "Mapeamentos de domínio"

#: includes/Admin/SettingsPage.php:383
msgid "Format: sprachcode=host, eine Zuordnung pro Zeile."
msgstr "Formato: sprachcode=host, uma atribuição por linha."

#: includes/Admin/SettingsPage.php:395
msgid "WooCommerce- und wp_mail-E-Mails übersetzen"
msgstr "Traduzir e-mails WooCommerce e wp_mail"

#: includes/Admin/SettingsPage.php:408
msgid "Suche in der Besuchersprache ausführen"
msgstr "Execute a pesquisa no idioma do visitante"

#: includes/Admin/SettingsPage.php:421
msgid "AMP-Seiten übersetzen"
msgstr "Traduzir páginas AMP"

#: includes/Admin/SettingsPage.php:425
msgid "Ausgeschlossene CSS-Selektoren"
msgstr "Seletores CSS excluídos"

#: includes/Admin/SettingsPage.php:427
msgid "Eine CSS-Klasse, ID oder ein Selektor pro Zeile."
msgstr "Uma classe, ID ou seletor CSS por linha."

#: includes/Admin/SettingsPage.php:461
msgid "Sprachumschalter"
msgstr "Alternador de idioma"

#: includes/Admin/SettingsPage.php:462
msgid "Wie und wo soll der Language-Switcher auf deiner Website erscheinen?"
msgstr "Como e onde o Language-Switcher deve aparecer no seu site?"

#: includes/Admin/SettingsPage.php:475
msgid "Switcher automatisch im Seitenfooter einfügen"
msgstr "Inserir automaticamente Switcher no rodapé da página"

#: includes/Admin/SettingsPage.php:479
msgid "Alternativ: Shortcode [deepglot_switcher] oder PHP do_action('deepglot_language_switcher') in deinem Theme."
msgstr "Alternativamente: Shortcode [deepglot_switcher] ou PHP do_action('deepglot_language_switcher') no seu tema."

#: includes/Admin/SettingsPage.php:484
msgid "Darstellung"
msgstr "Apresentação"

#: includes/Admin/SettingsPage.php:487
msgid "Inline-Liste"
msgstr "Lista embutida"

#: includes/Admin/SettingsPage.php:490
msgid "Dropdown"
msgstr "Descer"

#: includes/Admin/SettingsPage.php:496
msgid "Flaggenstil"
msgstr "Estilo de bandeira"

#: includes/Admin/SettingsPage.php:499
msgid "Rechteckig, matt"
msgstr "Retangular, mate"

#: includes/Admin/SettingsPage.php:502
msgid "Rechteckig, glänzend"
msgstr "Retangular, brilhante"

#: includes/Admin/SettingsPage.php:505
msgid "Kreis, matt"
msgstr "Círculo, fosco"

#: includes/Admin/SettingsPage.php:508
msgid "Kreis, glänzend"
msgstr "Círculo, brilhante"

#: includes/Admin/SettingsPage.php:511
msgid "Ohne Flagge"
msgstr "Sem bandeira"

#: includes/Admin/SettingsPage.php:517
msgid "Sprachbezeichnung"
msgstr "Designação de idioma"

#: includes/Admin/SettingsPage.php:520
msgid "Volle Bezeichnung („Deutsch\")"
msgstr "Nome completo (“Alemão”)"

#: includes/Admin/SettingsPage.php:523
msgid "ISO-Code („DE\")"
msgstr "ISO-Code (“DE”)"

#: includes/Admin/SettingsPage.php:529
msgid "Anzeigegerät"
msgstr "Dispositivo de exibição"

#: includes/Admin/SettingsPage.php:532
msgid "Auf allen Geräten zeigen"
msgstr "Mostrar em todos os dispositivos"

#: includes/Admin/SettingsPage.php:535
msgid "Nur Desktop (auf Mobile ausblenden)"
msgstr "Somente desktop (ocultar no celular)"

#: includes/Admin/SettingsPage.php:538
msgid "Nur Mobile (auf Desktop ausblenden)"
msgstr "Somente celular (ocultar no desktop)"

#: includes/Admin/SettingsPage.php:544
msgid "Mobile-Breakpoint (px)"
msgstr "Ponto de interrupção móvel (px)"

#: includes/Admin/SettingsPage.php:556
msgid "Standard 768 px. Unter dieser Breite gilt eine Seite als „Mobile\"."
msgstr "Padrão 768px. Abaixo dessa largura, uma página é considerada “móvel”."

#: includes/Admin/SettingsPage.php:561
msgid "Position auf der Seite"
msgstr "Posição na página"

#: includes/Admin/SettingsPage.php:564
msgid "Inline (an der eingebetteten Stelle)"
msgstr "Inline (no local incorporado)"

#: includes/Admin/SettingsPage.php:567
msgid "Floating: rechts unten"
msgstr "Flutuante: canto inferior direito"

#: includes/Admin/SettingsPage.php:570
msgid "Floating: links unten"
msgstr "Flutuante: canto inferior esquerdo"

#: includes/Admin/SettingsPage.php:573
msgid "Floating: rechts oben"
msgstr "Flutuante: canto superior direito"

#: includes/Admin/SettingsPage.php:576
msgid "Floating: links oben"
msgstr "Flutuante: canto superior esquerdo"

#: includes/Admin/SettingsPage.php:580
msgid "„Floating\" pinnt den Switcher mit position:fixed an die Ecke und scrollt mit. Kombiniert mit Auto-Inject = Weglot-Default-Verhalten."
msgstr "\"Flutuante\" fixa o Switcher no canto com position:fixed e rola com ele. Combinado com o comportamento padrão Auto-Inject = Weglot."

#: includes/Admin/SettingsPage.php:595
msgid "Bezeichnung sichtbar"
msgstr "Designação visível"

#: includes/Admin/SettingsPage.php:602
msgid "Reihenfolge der Sprachen"
msgstr "Ordem dos idiomas"

#: includes/Admin/SettingsPage.php:621
msgid "Per Drag-&-Drop neu anordnen. Greift sowohl im Shortcode als auch beim Auto-Inject."
msgstr "Reorganize usando arrastar e soltar. Funciona em Shortcode e injeção automática."

#: includes/Admin/SettingsPage.php:625
msgid "Eigene Flaggen pro Sprache (optional)"
msgstr "Bandeiras próprias por idioma (opcional)"

#: includes/Admin/SettingsPage.php:655
msgid "Leer lassen = Default-Flagge. Emoji (z. B. 🇺🇸 für EN→US-Markt) oder URL zu SVG/PNG. CSS-Sonderzeichen werden automatisch entfernt."
msgstr "Deixe em branco = sinalizador padrão. Emoji (por exemplo, 🇺🇸 para o mercado EN → EUA) ou URL a SVG/PNG. CSS caracteres especiais são removidos automaticamente."

#: includes/Admin/SettingsPage.php:660
msgid "Eigenes CSS für den Switcher"
msgstr "Possui CSS para Switcher"

#: includes/Admin/SettingsPage.php:668
msgid "Wird unmittelbar vor dem Switcher als <style>-Tag eingefügt. „<\" wird automatisch entfernt, damit kein Script-Tag eingeschleust werden kann."
msgstr "Inserido imediatamente antes de Switcher como a tag <style>. \"<\" é removido automaticamente para que nenhuma tag de script possa ser inserida."

#: includes/Admin/SettingsPage.php:673
msgid "Einstellungen speichern"
msgstr "Salvar configurações"

