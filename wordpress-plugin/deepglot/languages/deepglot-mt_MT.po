msgstr "Kif u fejn għandu jidher il-Language-Switcher fuq il-websajt tiegħek?"

#: includes/Admin/SettingsPage.php:475
msgid "Switcher automatisch im Seitenfooter einfügen"
msgstr "Daħħal awtomatikament Switcher fil-footer tal-paġna"

#: includes/Admin/SettingsPage.php:479
msgid "Alternativ: Shortcode [deepglot_switcher] oder PHP do_action('deepglot_language_switcher') in deinem Theme."
msgstr "Alternattivament: Shortcode [deepglot_switcher] jew PHP do_action('deepglot_language_switcher') fit-tema tiegħek."

