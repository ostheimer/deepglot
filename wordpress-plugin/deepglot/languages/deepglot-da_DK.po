msgstr "Backend URL"

#: includes/Admin/SettingsPage.php:252
msgid "Standard: https://deepglot.ai/api – nur ändern bei Self-Hosting."
msgstr "Standard: https://deepglot.ai/api – ændres kun for Self-Hosting."

#: includes/Admin/SettingsPage.php:264
msgid "Sprachen konfigurieren"
msgstr "Konfigurer sprog"

