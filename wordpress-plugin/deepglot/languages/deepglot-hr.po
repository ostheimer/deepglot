#. Plugin Name of the plugin
#: deepglot.php
#: includes/Admin/SettingsPage.php:34
#: includes/Admin/SettingsPage.php:35
msgid "Deepglot"
msgstr "Deepglot"

#. Plugin URI of the plugin
#: deepglot.php
msgid "https://deepglot.ai"
msgstr "https://deepglot.ai"

#. Description of the plugin
#: deepglot.php
msgid "Übersetzt WordPress-Inhalte mit Deepglot und einer kompatiblen Übersetzungs-API."
msgstr "Prevodi WordPress sadržaj pomoću Deepglot i kompatibilnog API-ja za prevođenje."

#. Author of the plugin
#: deepglot.php
msgid "Andreas Ostheimer"
msgstr "Andreas Ostheimer"

#. Author URI of the plugin
#: deepglot.php
msgid "https://www.ostheimer.at"
msgstr "https://www.ostheimer.at"

#: includes/Admin/NavMenuMetaBox.php:26
