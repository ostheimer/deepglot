# Copy this file to .env.selfhost and use it with:
# docker compose up --build -d

# PostgreSQL service settings used by docker-compose.yml
POSTGRES_DB=deepglot
POSTGRES_USER=deepglot
POSTGRES_PASSWORD=change-me

# App database connection strings used inside the app container
DATABASE_URL=postgresql://deepglot:change-me@db:5432/deepglot?schema=public
DATABASE_URL_UNPOOLED=postgresql://deepglot:change-me@db:5432/deepglot?schema=public

# Required for NextAuth
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Deepglot

# Keep disabled unless you explicitly want an instant demo login
DEEPGLOT_ENABLE_TEST_LOGIN=false
TEST_LOGIN_EMAIL=selfhost@deepglot.local
TEST_LOGIN_NAME=Deepglot Self-Host Admin
TEST_LOGIN_PASSWORD=change-this-password
TEST_LOGIN_ORGANIZATION_NAME=Deepglot Self-Hosted Workspace
TEST_LOGIN_ORGANIZATION_SLUG=deepglot-self-hosted
TEST_LOGIN_PROJECT_NAME=Deepglot Demo Project
TEST_LOGIN_PROJECT_DOMAIN=

# Optional OAuth providers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Stripe is optional for initial setup, but the app expects values to exist.
# Replace these with real keys before using billing in production.
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder

# Stripe Price IDs — one per paid plan × interval (must match
# stripePriceIdEnvKeys in src/lib/billing-plans.ts). FREE and ENTERPRISE
# have no Stripe price.
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_BUSINESS_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_ADVANCED_MONTHLY=
STRIPE_PRICE_ADVANCED_YEARLY=
STRIPE_PRICE_EXTENDED_MONTHLY=
STRIPE_PRICE_EXTENDED_YEARLY=

# Translation provider
TRANSLATION_PROVIDER=mock
OPENAI_TRANSLATION_MODEL=gpt-5-mini
OPENAI_API_KEY=
DEEPL_API_KEY=

# Email (Cloudflare Email Sending)
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_EMAIL_API_TOKEN=""
EMAIL_FROM="Deepglot <noreply@example.com>"

# Operational alerts — email to notify when a duplicate Stripe subscription is detected
# (Word quota alerts at 90%/100% go to the organization owner's email automatically)
DEEPGLOT_BILLING_ALERT_EMAIL=""
