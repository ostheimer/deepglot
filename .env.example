# ─── Database (Neon PostgreSQL, Variant A: 2 branches) ─────────────────────
# Local + Vercel Development + Vercel Preview → Neon branch "preview".
# Vercel Production only → Neon branch "prod". See README for setup steps.
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/deepglot?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/deepglot?sslmode=require"
# Optional runtime override. Useful on Vercel if an integration injects a
# branch-specific DATABASE_URL and Production must force the prod branch.
DEEPGLOT_DATABASE_URL=""

# ─── NextAuth v5 ──────────────────────────────────────────────────────────
# Local / Development:
# - AUTH_URL=http://localhost:3000
# - NEXT_PUBLIC_APP_URL=http://localhost:3000
# Preview:
# - leave AUTH_URL / NEXT_PUBLIC_APP_URL unset so the deployment host is used
# Production:
# - set AUTH_URL, NEXTAUTH_URL, and NEXT_PUBLIC_APP_URL to the canonical domain
AUTH_SECRET="your-random-32-char-secret"     # openssl rand -base64 32
# Optional stable encryption key for per-project provider API keys.
# If unset, AUTH_SECRET is used.
DEEPGLOT_SECRET_ENCRYPTION_KEY=""
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL=""
# On Vercel Preview / Production, billing return URLs can also fall back to
# exposed system variables such as VERCEL_BRANCH_URL, VERCEL_URL, and
# VERCEL_PROJECT_PRODUCTION_URL.

# ─── Test-Login (local / preview) ─────────────────────────────────────────
# Empty value keeps the default behavior:
# - enabled automatically in local development
# - enabled automatically on Vercel Preview
# - disabled on Vercel Production
DEEPGLOT_ENABLE_TEST_LOGIN=""
TEST_LOGIN_EMAIL="preview@deepglot.local"
TEST_LOGIN_NAME="Deepglot Test"
TEST_LOGIN_PASSWORD="deepglot-preview-login"
TEST_LOGIN_ORGANIZATION_NAME="Deepglot Test-Workspace"
TEST_LOGIN_ORGANIZATION_SLUG="deepglot-test-workspace"
TEST_LOGIN_PROJECT_NAME="Deepglot Demo-Projekt"
TEST_LOGIN_PROJECT_DOMAIN=""

# ─── Scheduled Workers ───────────────────────────────────────────────────
# Required in Vercel Production. Vercel Cron calls /api/webhooks/process with
# Authorization: Bearer $CRON_SECRET.
CRON_SECRET=""

# ─── Cloudflare DNS Automation ────────────────────────────────────────────
# Optional. Used by deployment/operations scripts when DNS records must be
# inspected or updated through the Cloudflare API.
CLOUDFLARE_API_TOKEN=""

# OAuth Providers (optional)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── Stripe ───────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe Price IDs
STRIPE_PRICE_STARTER_MONTHLY=""
STRIPE_PRICE_PROFESSIONAL_MONTHLY=""
STRIPE_PRICE_ENTERPRISE_MONTHLY=""

# ─── Translation APIs ─────────────────────────────────────────────────────
TRANSLATION_PROVIDER="openai"              # openai | openrouter | ollama | openai-compatible | deepl | mock
# Suggested setup:
# - Development: mock
# - Preview: mock
# - Production: openai
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_TRANSLATION_MODEL="gpt-5.5"

OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_TRANSLATION_MODEL="openai/gpt-5.5"

OLLAMA_BASE_URL="http://localhost:11434/v1"
OLLAMA_TRANSLATION_MODEL="llama3.3"
OLLAMA_API_KEY=""

# Generic overrides for openai-compatible gateways.
TRANSLATION_API_KEY=""
TRANSLATION_BASE_URL=""
TRANSLATION_MODEL=""

DEEPL_API_KEY=""

# ─── E-Mail (Cloudflare Email Sending) ────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_EMAIL_API_TOKEN=""
EMAIL_FROM="Deepglot <noreply@deepglot.ai>"

# ─── App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Deepglot"
