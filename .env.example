# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/deepglot?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/deepglot?sslmode=require"

# ─── NextAuth v5 ──────────────────────────────────────────────────────────
AUTH_SECRET="your-random-32-char-secret"     # openssl rand -base64 32
AUTH_URL="http://localhost:3000"

# OAuth Providers (optional)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── Stripe ───────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe Price IDs
STRIPE_PRICE_STARTER_MONTHLY=""
STRIPE_PRICE_PROFESSIONAL_MONTHLY=""
STRIPE_PRICE_ENTERPRISE_MONTHLY=""

# ─── Translation APIs ─────────────────────────────────────────────────────
DEEPL_API_KEY=""
OPENAI_API_KEY=""

# ─── E-Mail (Resend) ──────────────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="Deepglot <noreply@deepglot.com>"

# ─── App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Deepglot"
